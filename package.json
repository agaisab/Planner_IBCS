{
  "name": "planner_ibcs",
  "private": true,
  "version": "0.1.0",
  "description": "Planner IBCS – manager and employee panels sharing plans",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:manager": "npm --workspace apps/manager run dev",
    "dev:employee": "npm --workspace apps/employee run dev",
    "dev:backend": "npm --workspace packages/backend run dev",
    "dev": "npm-run-all -p dev:backend dev:manager dev:employee",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --if-present --workspaces"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
